set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_SYSTEM_PROCESSOR arm)

set(TOOLCHAIN_PREFIX arm-none-eabi)
set(TOOLCHAIN_HINTS)

if(DEFINED ENV{ARM_GNU_TOOLCHAIN_ROOT})
    list(APPEND TOOLCHAIN_HINTS "$ENV{ARM_GNU_TOOLCHAIN_ROOT}/bin")
endif()

find_program(ARM_GCC ${TOOLCHAIN_PREFIX}-gcc HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_AR ${TOOLCHAIN_PREFIX}-ar HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_GCC_AR ${TOOLCHAIN_PREFIX}-gcc-ar HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_GCC_RANLIB ${TOOLCHAIN_PREFIX}-gcc-ranlib HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_RANLIB ${TOOLCHAIN_PREFIX}-ranlib HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_ADDR2LINE ${TOOLCHAIN_PREFIX}-addr2line HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_LD ${TOOLCHAIN_PREFIX}-ld HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_NM ${TOOLCHAIN_PREFIX}-nm HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_OBJCOPY ${TOOLCHAIN_PREFIX}-objcopy HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_OBJDUMP ${TOOLCHAIN_PREFIX}-objdump HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_READELF ${TOOLCHAIN_PREFIX}-readelf HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_SIZE ${TOOLCHAIN_PREFIX}-size HINTS ${TOOLCHAIN_HINTS} REQUIRED)
find_program(ARM_STRIP ${TOOLCHAIN_PREFIX}-strip HINTS ${TOOLCHAIN_HINTS} REQUIRED)

set(CMAKE_C_COMPILER ${ARM_GCC} CACHE FILEPATH "C compiler" FORCE)
set(CMAKE_ASM_COMPILER ${ARM_GCC} CACHE FILEPATH "ASM compiler" FORCE)
set(CMAKE_AR ${ARM_AR} CACHE FILEPATH "Archiver" FORCE)
set(CMAKE_C_COMPILER_AR ${ARM_GCC_AR} CACHE FILEPATH "C compiler archiver" FORCE)
set(CMAKE_ASM_COMPILER_AR ${ARM_GCC_AR} CACHE FILEPATH "ASM compiler archiver" FORCE)
set(CMAKE_C_COMPILER_RANLIB ${ARM_GCC_RANLIB} CACHE FILEPATH "C compiler ranlib" FORCE)
set(CMAKE_ASM_COMPILER_RANLIB ${ARM_GCC_RANLIB} CACHE FILEPATH "ASM compiler ranlib" FORCE)
set(CMAKE_RANLIB ${ARM_RANLIB} CACHE FILEPATH "Ranlib" FORCE)
set(CMAKE_ADDR2LINE ${ARM_ADDR2LINE} CACHE FILEPATH "Addr2line" FORCE)
set(CMAKE_LINKER ${ARM_LD} CACHE FILEPATH "Linker" FORCE)
set(CMAKE_NM ${ARM_NM} CACHE FILEPATH "NM" FORCE)
set(CMAKE_OBJCOPY ${ARM_OBJCOPY} CACHE FILEPATH "Objcopy" FORCE)
set(CMAKE_OBJDUMP ${ARM_OBJDUMP} CACHE FILEPATH "Objdump" FORCE)
set(CMAKE_READELF ${ARM_READELF} CACHE FILEPATH "Readelf" FORCE)
set(CMAKE_SIZE ${ARM_SIZE} CACHE FILEPATH "Size" FORCE)
set(CMAKE_STRIP ${ARM_STRIP} CACHE FILEPATH "Strip" FORCE)

set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)
